---
import type { GetStaticPaths, ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import merge from 'lodash.merge';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';
import Layout from '~/layouts/PageLayout.astro';
import type { MetaData, Post } from '~/types';
import { blogPostRobots, fetchPosts } from '~/utils/blog';
import { findImage } from '~/utils/images';
import { cleanSlug, getCanonical } from '~/utils/permalinks';

// ✅ i18n
import { SUPPORTED_LOCALES, type Locale } from '~/lib/i18n';
import { extractFaqItems } from '~/utils/faq';

export const prerender = true;

export const getStaticPaths: GetStaticPaths = async () => {
  // Get raw collection entries for FAQ extraction
  const rawEntries = await getCollection('post');
  const bodyBySlug = new Map<string, string>();
  for (const entry of rawEntries) {
    const slug = cleanSlug((entry.filePath ?? entry.id).split('/').pop()!.replace(/\.mdx?$/i, ''));
    if (entry.body) bodyBySlug.set(slug, entry.body);
  }

  const all = await Promise.all(
    SUPPORTED_LOCALES.map(async (lang) => {
      const l = lang as Locale;
      const posts = await fetchPosts(l);
      return posts.map((post) => ({
        params: { lang: l, slug: post.slug! },
        props: {
          post,
          lang: l,
          faqItems: extractFaqItems(bodyBySlug.get(post.slug!)),
        },
      }));
    })
  );
  return all.flat();
};

const { post, faqItems } = Astro.props as { post: Post; faqItems: Array<{ question: string; answer: string }> };

const url = getCanonical(post.permalink);
const image = (await findImage(post.image)) as ImageMetadata | string | undefined;
const ogImage =
  !image ? undefined
  : typeof image === 'string'
    ? { url: image }
    : { url: image.src, width: image.width, height: image.height };

const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: { index: blogPostRobots?.index, follow: blogPostRobots?.follow },
    openGraph: { type: 'article', ...(ogImage ? { images: [ogImage] } : {}) },
  },
  post.metadata ? { ...post.metadata, canonical: post.metadata?.canonical || url } : {}
) as MetaData;

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.metadata?.description || post.excerpt || '',
  author: {
    '@type': 'Person',
    name: post.author || 'Olivier Demichel',
    url: `https://aeroxbefaster.com/${post.lang || 'fr'}/team/`,
  },
  publisher: {
    '@type': 'Organization',
    name: 'AeroX',
    url: 'https://aeroxbefaster.com',
  },
  datePublished: post.publishDate ? new Date(post.publishDate).toISOString() : undefined,
  dateModified: post.updateDate ? new Date(post.updateDate).toISOString() : (post.publishDate ? new Date(post.publishDate).toISOString() : undefined),
  mainEntityOfPage: { '@type': 'WebPage', '@id': String(url) },
  ...(ogImage ? { image: ogImage.url } : {}),
};
---
<Layout metadata={metadata}>
  <SinglePost post={{ ...post, image }} url={url}>
    {post.Content ? <post.Content /> : <Fragment set:html={post.content || ''} />}
  </SinglePost>
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  {faqItems.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    })} />
  )}
  <ToBlogLink />
  <RelatedPosts post={post} />
</Layout>
