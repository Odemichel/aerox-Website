    </Fragment>

    <Fragment slot="paragraph">
      <span set:html={t(dict, 'home.hero.paragraph')}></span>
    </Fragment>

    <Fragment slot="content">
      {t(dict, 'home.hero.countdown.prefix')} <CountDown targetDate={new Date(COUNTDOWN_TARGET)} /> !
    </Fragment>
  </Hero>

  <style is:inline>
    .glitch-active {
      animation: glitch-base 0.25s step-end forwards;
    }
    .glitch-active::before,
    .glitch-active::after {
      content: attr(data-text);
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      overflow: hidden;
      pointer-events: none;
      will-change: clip-path, transform;
    }
    .glitch-active::before {
      text-shadow: -3px 0 hsl(210,60%,30%);
      animation: glitch-top 0.25s step-end forwards;
    }
    .glitch-active::after {
      text-shadow: 3px 0 hsl(35,95%,58%);
      animation: glitch-bottom 0.25s step-end forwards;
    }

    @keyframes glitch-base {
      0%   { transform: translate(0); }
      10%  { transform: translate(-3px, 1px); }
      20%  { transform: translate(2px, -1px); }
      30%  { transform: translate(-1px, 0); }
      40%  { transform: translate(3px, 1px); }
      50%  { transform: translate(0); }
      60%  { transform: translate(-2px, -1px); }
      70%  { transform: translate(1px, 1px); }
      80%  { transform: translate(0); }
      90%  { transform: translate(-1px, 0); }
      100% { transform: translate(0); }
    }
    @keyframes glitch-top {
      0%   { clip-path: inset(10% 0 70% 0); transform: translate(-5px, 0) skewX(-3deg); }
      10%  { clip-path: inset(50% 0 20% 0); transform: translate(4px, 0) skewX(2deg); }
      20%  { clip-path: inset(5% 0 80% 0);  transform: translate(-6px, -1px); }
      30%  { clip-path: inset(35% 0 40% 0); transform: translate(3px, 0) skewX(-4deg); }
      40%  { clip-path: inset(70% 0 5% 0);  transform: translate(-4px, 1px) skewX(2deg); }
      50%  { clip-path: inset(15% 0 60% 0); transform: translate(5px, 0); }
      60%  { clip-path: inset(55% 0 15% 0); transform: translate(-3px, -1px) skewX(-2deg); }
      70%  { clip-path: inset(25% 0 50% 0); transform: translate(6px, 0) skewX(3deg); }
      80%  { clip-path: inset(45% 0 30% 0); transform: translate(-2px, 1px); }
      90%  { clip-path: inset(80% 0 0% 0);  transform: translate(4px, 0) skewX(-1deg); }
      100% { clip-path: inset(0 0 100% 0);  transform: translate(0); }
    }
    @keyframes glitch-bottom {
      0%   { clip-path: inset(60% 0 10% 0); transform: translate(4px, 0) skewX(4deg); }
      10%  { clip-path: inset(20% 0 55% 0); transform: translate(-5px, 1px) skewX(-2deg); }
      20%  { clip-path: inset(75% 0 0% 0);  transform: translate(6px, 0); }
      30%  { clip-path: inset(8% 0 65% 0);  transform: translate(-3px, -1px) skewX(3deg); }
      40%  { clip-path: inset(40% 0 35% 0); transform: translate(5px, 0) skewX(-3deg); }
      50%  { clip-path: inset(65% 0 10% 0); transform: translate(-6px, 1px); }
      60%  { clip-path: inset(30% 0 45% 0); transform: translate(3px, 0) skewX(2deg); }
      70%  { clip-path: inset(85% 0 0% 0);  transform: translate(-4px, -1px) skewX(-4deg); }
      80%  { clip-path: inset(12% 0 70% 0); transform: translate(5px, 0); }
      90%  { clip-path: inset(50% 0 25% 0); transform: translate(-3px, 1px) skewX(1deg); }
      100% { clip-path: inset(0 0 100% 0);  transform: translate(0); }
    }

    @media (prefers-reduced-motion: reduce) {
      .glitch-active,
      .glitch-active::before,
      .glitch-active::after { animation: none !important; }
    }
  </style>

  <script is:inline>
    function initHeroRotation() {
      var el = document.getElementById('hero-rotating');
      if (!el || el.dataset.init === '1') return;
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      try {
        var texts = JSON.parse(el.getAttribute('data-texts') || '[]');
      } catch(e) { return; }
      if (texts.length < 2) return;

      el.dataset.init = '1';
      var idx = 0;

      function glitchSwap(target) {
        el.classList.add('glitch-active');

        /* Swap text at midpoint (150ms into 300ms animation) */
        setTimeout(function() {
          el.textContent = target;
          el.setAttribute('data-text', target);
        }, 125);

        /* Clean up after animation ends */
        setTimeout(function() {
          el.classList.remove('glitch-active');
        }, 270);
      }

      setInterval(function() {
        idx = (idx + 1) % texts.length;
        glitchSwap(texts[idx]);
      }, 1600);
    }

    document.addEventListener('DOMContentLoaded', initHeroRotation);
    document.addEventListener('astro:page-load', initHeroRotation);
    if (document.readyState !== 'loading') initHeroRotation();
  </script>

