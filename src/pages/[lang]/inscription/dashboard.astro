---
import Prices from '../../../components/widgets/Pricing.astro';
import { COUNTDOWN_TARGET } from '~/config/countdown';

import Layout from '../../../layouts/PageLayout.astro';
import { getDict, t } from '~/lib/i18n';

const { lang } = Astro.params;
const dict = getDict(lang);

const metadata = {
  title: t(dict, 'dashboard.meta.title'),
  description: t(dict, 'dashboard.meta.description'),
};
const role = t(dict, 'dashboard.role');
const email = t(dict, 'dashboard.email');
const choosePack = t(dict, 'dashboard.choosePack');
const licence = t(dict, 'dashboard.licence');
const noLicence = t(dict, 'dashboard.noLicence');
const studio = t(dict, 'dashboard.studio');
const noStudio = t(dict, 'dashboard.noStudio');
const pendingActivation = t(dict, 'dashboard.pendingActivation');
const activeBf = t(dict, 'dashboard.activeBf');
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-6">
    <h1 class="text-3xl font-bold mb-6 text-center">
      {t(dict, 'dashboard.title')}
    </h1>
    <div id="dashboard-content" data-role={role} data-email={email} data-choosePack={choosePack} data-licence={licence} data-noLicence={noLicence} data-studio={studio} data-noStudio={noStudio} data-pendingActivation={pendingActivation} data-activeBf={activeBf} class="text-center">
      <p>{t(dict, 'dashboard.loading')}</p>
    </div>

    <!-- ✅ Script côté client -->
    <script>
      import { supabase } from '../../../config/supabaseClient';

      async function loadDashboard() {
        console.log('➡️ Init dashboard');
        const content = document.getElementById('dashboard-content');
        const labelRole = content?.dataset.role || 'Role';
        const labelEmail = content?.dataset.email || 'Email';
        const choosePack = content?.dataset.choosepack || "Choisis ton pack pour profiter d'AeroX";
        const labelLicence = content?.dataset.licence || 'Licence';
        const labelNoLicence = content?.dataset.nolicence || 'Non définie';
        const labelStudio = content?.dataset.studio || 'Studio';
        const labelNoStudio = content?.dataset.nostudio || 'Non renseigné';
        const labelPendingActivation = content?.dataset.pendingactivation || "En attente d'activation";
        const labelActiveBf = content?.dataset.activebf || 'Compte Bike-Fitter actif';
        if (!content) return;

        // Vérifie si l'utilisateur est connecté
        const { data: userData, error } = await supabase.auth.getUser();
        if (error || !userData?.user) {
          content.innerHTML = `<p class="text-red-600">Tu n'es pas connect\u00e9.</p>`;
          return;
        }

        const user = userData.user;
        console.log('Connecté :', user.email);

        // Récupère son profil complet
        const { data: profile, error: profileError } = await supabase
          .from('users')
          .select('role, is_active, licencetype, studio_name')
          .eq('id', user.id)
          .maybeSingle();

        if (profileError) {
          console.error('Erreur chargement profil:', profileError);
        }

        if (profile) {
          let detailsHtml = '';

          if (profile.role === 'bike-fitter' || profile.role === 'pending_bf') {
            // Bike-Fitter / pending BF display
            const studioDisplay = profile.studio_name || labelNoStudio;
            detailsHtml += `<p><strong>${labelStudio} :</strong> ${studioDisplay}</p>`;
            if (profile.role === 'pending_bf') {
              detailsHtml += `<p class="text-yellow-600 font-semibold mt-1">${labelPendingActivation}</p>`;
            } else {
              detailsHtml += `<p class="text-green-600 font-semibold mt-1">${labelActiveBf}</p>`;
            }
          } else if (profile.role === 'admin') {
            // Admin: just show role, no licence
          } else {
            // Rider display (default)
            if (profile.is_active) {
              detailsHtml += `<p><strong>${labelLicence} :</strong> ${profile.licencetype || labelNoLicence}</p>`;
            } else {
              detailsHtml += `<p class="text-primary font-semibold text-center mt-2">${choosePack}</p>`;
            }
          }

          content.innerHTML = `
        <div class="mt-6 p-6 border rounded-lg bg-gray-50 dark:bg-gray-800 text-left inline-block">
          <p><strong>${labelEmail} :</strong> ${user.email}</p>
          <p><strong>${labelRole} :</strong> ${profile.role}</p>
          ${detailsHtml}
        </div>`;
        } else {
          // public.users est créé automatiquement par le trigger
          // handle_email_confirmed côté Supabase à la validation de l'email.
          // Si le profil n'existe pas encore, la confirmation email est peut-être
          // encore en cours de propagation — on retente après un court délai.
          await new Promise(r => setTimeout(r, 1500));
          const { data: retry } = await supabase
            .from('users')
            .select('role, is_active, licencetype, studio_name')
            .eq('id', user.id)
            .maybeSingle();

          if (retry) {
            loadDashboard();
            return;
          }
          content.innerHTML = `<p class="text-red-600">Profil non trouvé. Vérifie que ton email est bien confirmé.</p>`;
        }
      }

      loadDashboard();
    </script>
  </section>

  <!-- Cartes de prix (déjà traduites) -->
  <Prices
    title={t(dict, 'home.prices.title')}
    id="pricing"
    subtitle={t(dict, 'home.prices.subtitle')}
    subsubtitle={t(dict, 'home.prices.subsubtitle')}
    prices={[
      {
        title: t(dict, 'home.prices.packDiscover.title'),
        subtitle: t(dict, 'home.prices.packDiscover.subtitle'),
        price: '5',
        period: t(dict, 'home.prices.packDiscover.period'),
        items: [
          { description: t(dict, 'home.prices.packDiscover.items.1'), icon: 'tabler:award-filled' },
          { description: t(dict, 'home.prices.packDiscover.items.2'), icon: 'tabler:award-filled' },
        ],
        callToAction: {
          target: '_blank',
          text: t(dict, 'home.prices.packDiscover.cta'),
          href: '#',
        },
      },
      {
        title: t(dict, 'home.prices.packPioneer.title'),
        subtitle: t(dict, 'home.prices.packPioneer.subtitle'),
        countdownTarget: new Date(COUNTDOWN_TARGET),
        price: '20',
        period: t(dict, 'home.prices.packPioneer.period'),
        items: [
          { description: t(dict, 'home.prices.packPioneer.items.1'), icon: 'tabler:award-filled' },
          { description: t(dict, 'home.prices.packPioneer.items.2'), icon: 'tabler:currency-euro' },
          { description: t(dict, 'home.prices.packPioneer.items.3'), icon: 'tabler:brand-whatsapp-filled' },
          { description: t(dict, 'home.prices.packPioneer.items.4'), icon: 'tabler:binary-tree-filled' },
        ],
        callToAction: {
          id: 'btn-checkout',
          text: t(dict, 'home.prices.packPioneer.cta'),
        },
        hasRibbon: true,
        ribbonTitle: t(dict, 'home.prices.packPioneer.ribbon'),
      },
      {
        title: t(dict, 'home.prices.packProgress.title'),
        hasChoice: true,
        title1: t(dict, 'home.prices.packProgress.title1'),
        subtitle1: t(dict, 'home.prices.packProgress.subtitle1'),
        price1: 140,
        period1: t(dict, 'home.prices.packProgress.period1'),
        items1: [
          { description: t(dict, 'home.prices.packProgress.items1.1'), icon: 'tabler:award-filled' },
          { description: t(dict, 'home.prices.packProgress.items1.2'), icon: 'tabler:binary-tree-filled' },
          { description: t(dict, 'home.prices.packProgress.items1.3'), icon: 'tabler:target-arrow' },
        ],
        callToAction1: {
          target: '_blank',
          text: t(dict, 'home.prices.packProgress.cta1'),
          href: '#',
        },
        title2: t(dict, 'home.prices.packProgress.title2'),
        subtitle2: t(dict, 'home.prices.packProgress.subtitle2'),
        price2: 15,
        period2: t(dict, 'home.prices.packProgress.period2'),
        items2: [
          { description: t(dict, 'home.prices.packProgress.items2.1'), icon: 'tabler:award-filled' },
          { description: t(dict, 'home.prices.packProgress.items2.2'), icon: 'tabler:target-arrow' },
        ],
        callToAction2: {
          target: '_blank',
          text: t(dict, 'home.prices.packProgress.cta2'),
          href: '#',
        },
      },
    ]}
  />

  <script is:inline>
    const redirectUrl = `/${document.documentElement.lang || 'fr'}/contact/`;
    const redirectText = document.documentElement.lang === 'en' ? 'Redirecting…' : 'Redirection…';

    const withLoading = (btn) => {
      if (!btn) return;
      btn.disabled = true;
      btn.innerHTML = redirectText;
      setTimeout(() => {
        window.location.href = redirectUrl;
      }, 300);
    };

    document.getElementById('btn-checkout')?.addEventListener('click', (e) => {
      withLoading(e.currentTarget);
    });
  </script>

