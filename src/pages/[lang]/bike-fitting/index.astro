---
import type { GetStaticPaths } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';

import aeroxHero from '~/assets/images/aerox-hero.jpg';
import bikePower from '~/assets/images/bike-fitter/bikefitting-bike-power.jpg';
import aeroxGain from '~/assets/images/bike-fitter/aerox-gain.png';

import { SUPPORTED_LOCALES, type Locale, getDict, t } from '~/lib/i18n';
import { SITE } from 'astrowind:config';

export const prerender = true;

export const getStaticPaths: GetStaticPaths = async () => SUPPORTED_LOCALES.map((lang) => ({ params: { lang } }));

const lang = (Astro.params.lang as Locale) ?? 'fr';
const dict = getDict(lang);

const metadata = {
  title: t(dict, 'bf.meta.title'),
  description: t(dict, 'bf.meta.description'),
  robots: { index: true, follow: true },
  openGraph: {
    images: [{ url: '~/assets/images/bike-fitter/aerox-gain.png', alt: t(dict, 'bf.gain.img.alt') }],
  },
};

const homeHref = `/${lang}/`;
const blogBfHref = `/${lang}/blog/BF-mesurer-${lang}/`;

/* ===== FAQPage JSON-LD ===== */
const faqItems = [1, 2, 3, 4, 5].map((i) => ({
  '@type': 'Question' as const,
  name: t(dict, `bf.faq.q${i}`),
  acceptedAnswer: {
    '@type': 'Answer' as const,
    text: t(dict, `bf.faq.a${i}`),
  },
}));

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems,
};

/* ===== Service JSON-LD ===== */
const siteOrigin = SITE?.site ? new URL(SITE.site).origin : Astro.url.origin;
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'AeroX Bike Fitting',
  description: t(dict, 'bf.meta.description'),
  provider: {
    '@type': 'Organization',
    name: 'AeroX',
    url: siteOrigin,
  },
  url: `${siteOrigin}/${lang}/bike-fitting/`,
  areaServed: 'Worldwide',
  serviceType: 'Aerodynamic Bike Fitting Software',
};

/* ===== SoftwareApplication JSON-LD (B2B) ===== */
const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'AeroX',
  applicationCategory: 'SportsApplication',
  operatingSystem: 'macOS, Windows',
  description: t(dict, 'bf.meta.description'),
  url: `${siteOrigin}/${lang}/bike-fitting/`,
  audience: {
    '@type': 'BusinessAudience',
    audienceType: 'Bike Fitters',
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    availability: 'https://schema.org/PreOrder',
    description: lang === 'fr' ? 'Contactez-nous pour un devis professionnel' : 'Contact us for a professional quote',
  },
};

/* ===== HowTo JSON-LD ===== */
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: lang === 'fr' ? 'Comment réaliser un bike fitting aérodynamique avec AeroX' : 'How to perform an aerodynamic bike fitting with AeroX',
  description: t(dict, 'bf.meta.description'),
  step: [1, 2, 3].map((i) => ({
    '@type': 'HowToStep',
    name: t(dict, `bf.steps.s${i}.title`),
    text: t(dict, `bf.steps.s${i}.desc`),
  })),
};

/* ===== Review JSON-LD ===== */
const reviews = [
  { name: 'Marcelo Rocha', quote: t(dict, 'bf.social.rocha.quote') },
  { name: 'Marcelo Muniz Machado', quote: t(dict, 'bf.social.muniz.quote') },
  { name: 'Mark Gerlando', quote: t(dict, 'bf.social.gerlando.quote') },
];
const reviewSchema = reviews.map((r) => ({
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: {
    '@type': 'SoftwareApplication',
    name: 'AeroX',
  },
  author: {
    '@type': 'Person',
    name: r.name,
  },
  reviewBody: r.quote,
}));
---

<Layout metadata={metadata}>
  <!-- JSON-LD schemas -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  {reviewSchema.map((r) => (
    <script type="application/ld+json" set:html={JSON.stringify(r)} />
  ))}

  <!-- 1. HERO — full-width image + text overlay -->
  <section class="relative not-prose overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={aeroxHero.src}
        width={aeroxHero.width}
        height={aeroxHero.height}
        alt={t(dict, 'bf.hero.img.alt')}
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-20 md:py-32">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-primary mb-4">
          {t(dict, 'bf.hero.tagline')}
        </p>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6 text-white">
          {t(dict, 'bf.hero.title.l1')}<br />
          <span class="text-primary">{t(dict, 'bf.hero.title.l2')}</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-200 max-w-xl" set:html={t(dict, 'bf.hero.text')} />
        <div class="mt-6 flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-1.5 bg-primary/20 backdrop-blur-sm rounded-full px-4 py-1.5 border border-primary/30">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            <span class="text-sm font-bold text-white">{lang === 'fr' ? 'Résultats visibles' : 'Visible results'}</span>
          </span>
          <span class="inline-flex items-center gap-1.5 bg-primary/20 backdrop-blur-sm rounded-full px-4 py-1.5 border border-primary/30">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            <span class="text-sm font-bold text-white">{lang === 'fr' ? 'Mesure en direct' : 'Live measurement'}</span>
          </span>
          <span class="inline-flex items-center gap-1.5 bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 border border-white/20">
            <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-sm font-semibold text-gray-200">{lang === 'fr' ? '2 min install' : '2 min setup'}</span>
          </span>
        </div>
        <div class="mt-8">
          <a
            href="#contact-bf"
            class="btn-primary inline-flex items-center gap-2 px-6 py-3 text-lg rounded-md font-semibold"
          >
            {t(dict, 'bf.hero.cta')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Bloc définition citable — optimisé GEO/AI Overviews -->
  <section class="relative not-prose">
    <div class="mx-auto max-w-4xl px-4 md:px-6 py-6">
      <p class="text-sm text-muted leading-relaxed">{t(dict, 'bf.definition')}</p>
      <p class="text-xs text-muted/60 mt-2 italic">{t(dict, 'bf.lastUpdated')}</p>
    </div>
  </section>

  <!-- 2. BÉNÉFICES -->
  <Features
    columns={2}
    title={t(dict, 'bf.benefits.title')}
    items={[
      {
        title: t(dict, 'bf.benefits.b1.title'),
        description: t(dict, 'bf.benefits.b1.desc'),
        icon: 'tabler:chart-bar',
      },
      {
        title: t(dict, 'bf.benefits.b2.title'),
        description: t(dict, 'bf.benefits.b2.desc'),
        icon: 'tabler:star',
      },
      {
        title: t(dict, 'bf.benefits.b3.title'),
        description: t(dict, 'bf.benefits.b3.desc'),
        icon: 'tabler:repeat',
      },
      {
        title: t(dict, 'bf.benefits.b4.title'),
        description: t(dict, 'bf.benefits.b4.desc'),
        icon: 'tabler:plug-connected',
      },
    ]}
  />

  <!-- VISUAL PROOF — image plein fond + glassmorphism overlay + aerox-gain -->
  <section class="relative not-prose scroll-mt-[72px] overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={bikePower.src}
        width={bikePower.width}
        height={bikePower.height}
        alt={t(dict, 'bf.visual.img.alt')}
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-black/30"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 md:px-6 py-16 md:py-24">
      <div class="flex flex-col items-center md:flex-row md:items-stretch md:justify-center gap-6 md:gap-12">
        <!-- Aerox gain overlay — 450px fixe -->
        <div class="w-[85%] md:w-[500px] md:max-w-[45%] md:shrink-0 flex items-center justify-center">
          <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-4 border border-white/15 shadow-2xl inline-block">
            <img
              src={aeroxGain.src}
              width={aeroxGain.width}
              height={aeroxGain.height}
              alt={t(dict, 'bf.gain.img.alt')}
              class="block w-full rounded-xl"
              loading="lazy"
            />
          </div>
        </div>
        <!-- Glassmorphism text card — 33% -->
        <div class="w-[85%] md:w-1/3 flex">
          <div class="w-full bg-white/75 dark:bg-slate-800/75 backdrop-blur-sm border border-gray-200 dark:border-slate-600 rounded-2xl p-8 md:p-10 shadow-2xl flex flex-col justify-center">
            <h2 class="text-2xl md:text-3xl font-bold mb-4 text-default">{t(dict, 'bf.visual.title')}</h2>
            <p class="text-lg text-muted">{t(dict, 'bf.visual.subtitle')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CE QUE MESURE AEROX — contenu enrichi + liens internes -->
  <section class="relative not-prose scroll-mt-[72px]">
    <div class="relative mx-auto max-w-4xl px-4 md:px-6 py-12 md:py-16">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-8">{t(dict, 'bf.metrics.title')}</h2>
      <div class="prose prose-lg dark:prose-invert max-w-none text-muted">
        <p set:html={t(dict, 'bf.metrics.intro')} />
        <div class="grid md:grid-cols-2 gap-6 my-8 not-prose">
          {[
            { i: 1, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>' },
            { i: 2, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>' },
            { i: 3, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>' },
            { i: 4, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>' },
          ].map(({ i, icon }) => (
            <div class="flex gap-3 items-start bf-fade-in">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0 mt-1">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" set:html={icon} />
              </div>
              <div>
                <p class="font-semibold text-default mb-1">{t(dict, `bf.metrics.m${i}.title`)}</p>
                <p class="text-sm text-muted">{t(dict, `bf.metrics.m${i}.desc`)}</p>
              </div>
            </div>
          ))}
        </div>
        <p set:html={t(dict, 'bf.metrics.outro')} />
      </div>

      <!-- Liens internes -->
      <div class="mt-8 grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
        <a href={blogBfHref} class="group flex items-start gap-3 p-4 rounded-xl border border-gray-200 dark:border-slate-700 hover:border-primary/50 hover:shadow-md transition-all">
          <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-default group-hover:text-primary transition-colors">{t(dict, 'bf.links.blog')}</p>
            <p class="text-xs text-muted mt-0.5">{lang === 'fr' ? 'Article de blog' : 'Blog post'}</p>
          </div>
        </a>
        <a href={homeHref} class="group flex items-start gap-3 p-4 rounded-xl border border-gray-200 dark:border-slate-700 hover:border-primary/50 hover:shadow-md transition-all">
          <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-default group-hover:text-primary transition-colors">{t(dict, 'bf.links.home')}</p>
            <p class="text-xs text-muted mt-0.5">{lang === 'fr' ? 'Page principale' : 'Main page'}</p>
          </div>
        </a>
      </div>

      <!-- CTA intermédiaire -->
      <div class="mt-10 text-center">
        <a href="#contact-bf" class="btn-primary inline-flex items-center gap-2 px-6 py-3 text-lg rounded-md font-semibold">
          {t(dict, 'bf.metrics.cta')}
        </a>
      </div>
    </div>
  </section>

  <!-- COMMENT ÇA MARCHE — 3 étapes -->
  <section class="relative not-prose scroll-mt-[72px] bg-gray-50 dark:bg-slate-900/50">
    <div class="relative mx-auto max-w-5xl px-4 md:px-6 py-12 md:py-16">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-10">{t(dict, 'bf.steps.title')}</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {[1, 2, 3].map((i) => (
          <div class="flex flex-col items-center text-center bf-fade-in">
            <div class="w-14 h-14 rounded-full bg-primary text-white flex items-center justify-center text-xl font-bold mb-4">{i}</div>
            <h3 class="text-lg font-semibold mb-2">{t(dict, `bf.steps.s${i}.title`)}</h3>
            <p class="text-sm text-muted">{t(dict, `bf.steps.s${i}.desc`)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TABLEAU COMPARATIF — AeroX vs Soufflerie vs Fitting classique -->
  <section class="relative not-prose scroll-mt-[72px]">
    <div class="mx-auto max-w-4xl px-4 md:px-6 py-10 md:py-14">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-8">{t(dict, 'bf.table.title')}</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-primary/10 dark:bg-primary/20">
              <th class="text-left px-4 py-3 font-semibold">{t(dict, 'bf.table.col1')}</th>
              <th class="text-left px-4 py-3 font-semibold text-primary">{t(dict, 'bf.table.col2')}</th>
              <th class="text-left px-4 py-3 font-semibold">{t(dict, 'bf.table.col3')}</th>
              <th class="text-left px-4 py-3 font-semibold">{t(dict, 'bf.table.col4')}</th>
            </tr>
          </thead>
          <tbody>
            {[
              { key: 'cost', highlight: true },
              { key: 'aero', highlight: true },
              { key: 'access', highlight: false },
              { key: 'duration', highlight: true },
              { key: 'followup', highlight: true },
            ].map(({ key, highlight }, idx) => (
              <tr class={`border-b border-gray-200 dark:border-slate-700 ${idx % 2 === 1 ? 'bg-gray-50 dark:bg-slate-800/30' : ''}`}>
                <td class="px-4 py-3 font-medium">{t(dict, `bf.table.${key}`)}</td>
                <td class={`px-4 py-3 ${highlight ? 'text-primary font-semibold' : ''}`}>{t(dict, `bf.table.${key}.aerox`)}</td>
                <td class="px-4 py-3">{t(dict, `bf.table.${key}.tunnel`)}</td>
                <td class="px-4 py-3 text-muted">{t(dict, `bf.table.${key}.classic`)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-muted/60 text-center mt-3 italic">{t(dict, 'bf.lastUpdated')}</p>
    </div>
  </section>

  <!-- 4. PREUVE SOCIALE — Bike fitters -->
  <section class="relative not-prose scroll-mt-[72px] overflow-hidden">
    <!-- Globe SVG en fond -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
      <svg class="w-[250px] h-[250px] md:w-[350px] md:h-[350px] text-primary opacity-[0.5] dark:opacity-[0.55]" viewBox="0 0 800 800" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="400" cy="400" r="340" stroke="currentColor" stroke-width="2"/>
        <ellipse cx="400" cy="400" rx="340" ry="340" stroke="currentColor" stroke-width="1.2"/>
        <ellipse cx="400" cy="400" rx="220" ry="340" stroke="currentColor" stroke-width="1.2"/>
        <ellipse cx="400" cy="400" rx="100" ry="340" stroke="currentColor" stroke-width="1"/>
        <ellipse cx="400" cy="400" rx="340" ry="100" stroke="currentColor" stroke-width="1"/>
        <ellipse cx="400" cy="280" rx="300" ry="60" stroke="currentColor" stroke-width="0.8"/>
        <ellipse cx="400" cy="520" rx="300" ry="60" stroke="currentColor" stroke-width="0.8"/>
        <ellipse cx="400" cy="180" rx="220" ry="40" stroke="currentColor" stroke-width="0.6"/>
        <ellipse cx="400" cy="620" rx="220" ry="40" stroke="currentColor" stroke-width="0.6"/>
        <path d="M260 540 C290 480 350 430 390 405" stroke="currentColor" stroke-width="2.5" fill="none" marker-end="url(#globeArrow)"/>
        <path d="M230 320 C270 340 340 370 390 395" stroke="currentColor" stroke-width="2.5" fill="none" marker-end="url(#globeArrow)"/>
        <path d="M560 270 C530 310 460 360 410 395" stroke="currentColor" stroke-width="2.5" fill="none" marker-end="url(#globeArrow)"/>
        <defs>
          <marker id="globeArrow" markerWidth="10" markerHeight="10" refX="8" refY="5" orient="auto">
            <path d="M0 0 L10 5 L0 10 Z" fill="currentColor"/>
          </marker>
        </defs>
        <circle cx="260" cy="540" r="8" fill="currentColor"/>
        <circle cx="230" cy="320" r="8" fill="currentColor"/>
        <circle cx="560" cy="270" r="8" fill="currentColor"/>
        <circle cx="400" cy="400" r="10" fill="currentColor" opacity="0.7"/>
      </svg>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 md:px-6 py-12 md:py-16">
      <div class="max-w-4xl mx-auto text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold mb-2">{t(dict, 'bf.testimonial.title')}</h2>
        <p class="text-lg text-muted" set:html={t(dict, 'bf.social.subtitle')} />
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {[
          { name: 'Marcelo Rocha', initials: 'MR', role: t(dict, 'bf.social.rocha.role'), location: t(dict, 'bf.social.rocha.location'), quote: t(dict, 'bf.social.rocha.quote'), url: 'https://marcelorocha.com/', domain: 'marcelorocha.com' },
          { name: 'Marcelo Muniz Machado', initials: 'MM', role: t(dict, 'bf.social.muniz.role'), location: t(dict, 'bf.social.muniz.location'), quote: t(dict, 'bf.social.muniz.quote'), url: 'https://saudem3bikefit.com.br/', domain: 'saudem3bikefit.com.br' },
          { name: 'Mark Gerlando', initials: 'MG', role: t(dict, 'bf.social.gerlando.role'), location: t(dict, 'bf.social.gerlando.location'), quote: t(dict, 'bf.social.gerlando.quote'), url: 'https://www.ridescience.com/', domain: 'ridescience.com' },
        ].map((fitter) => (
          <article class="flex flex-col rounded-2xl shadow-xl dark:shadow-none dark:border dark:border-slate-600 bg-white dark:bg-slate-800/50 p-5 md:p-6 bf-fade-in hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
            <div class="flex items-center gap-4 mb-4">
              <div class="h-12 w-12 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                <span class="text-primary text-lg font-bold">{fitter.initials}</span>
              </div>
              <div>
                <p class="font-semibold text-base">{fitter.name}</p>
                <p class="text-xs text-muted">{fitter.location}</p>
              </div>
            </div>
            <hr class="border-slate-200 dark:border-slate-600 mb-4" />
            <blockquote class="text-sm text-muted italic mb-4 border-l-2 border-primary/30 pl-3">
              "{fitter.quote}"
            </blockquote>
            <p class="text-xs text-accent mb-4">{fitter.role}</p>
            <a href={fitter.url} target="_blank" rel="noopener noreferrer" class="mt-auto inline-flex items-center gap-1 text-primary text-sm font-medium hover:underline">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
              {fitter.domain}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. FAQ -->
  <section class="relative not-prose scroll-mt-[72px]">
    <div class="relative mx-auto max-w-4xl px-4 md:px-6 py-12 md:py-16">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-8">{t(dict, 'bf.faq.title')}</h2>
      <div class="space-y-4">
        {[1, 2, 3, 4, 5].map((i) => (
          <div class="rounded-xl border border-gray-200 dark:border-slate-700 overflow-hidden transition-colors">
            <div class="px-5 py-4">
              <h3 class="font-semibold text-base text-default">{t(dict, `bf.faq.q${i}`)}</h3>
              <p class="mt-2 text-sm text-muted">{t(dict, `bf.faq.short${i}`)}</p>
              <details class="mt-2 group">
                <summary class="cursor-pointer inline-flex items-center text-muted dark:hover:text-primary font-medium select-none text-sm">
                  {t(dict, `bf.faq.more${i}`)}
                  <svg class="w-4 h-4 ml-1 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="mt-2 p-3 rounded-xl dark:bg-black/50 text-muted text-sm leading-relaxed">
                  {t(dict, `bf.faq.a${i}`)}
                </div>
              </details>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. FORMULAIRE DE CONTACT -->
  <section id="contact-bf" class="relative not-prose scroll-mt-[72px]">
    <div class="relative mx-auto max-w-3xl px-4 md:px-6 py-12 md:py-16">
      <div class="text-center p-6 md:p-10 rounded-2xl shadow-xl dark:shadow-none dark:border dark:border-slate-600">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tighter mb-4">{t(dict, 'bf.cta.title')}</h2>
        <p class="text-xl text-muted dark:text-slate-400 mb-8">{t(dict, 'bf.cta.subtitle')}</p>

        <form
          id="form-bf"
          class="flex flex-col items-center gap-4 max-w-md mx-auto"
          data-success={t(dict, 'bf.form.success')}
          data-error={t(dict, 'bf.form.error')}
        >
          <input
            type="text"
            id="name-bf"
            placeholder={t(dict, 'bf.form.name.placeholder')}
            required
            class="w-full border rounded p-3 text-secondary"
          />
          <input
            type="email"
            id="email-bf"
            placeholder={t(dict, 'bf.form.email.placeholder')}
            required
            class="w-full border rounded p-3 text-secondary"
          />
          <textarea
            id="message-bf"
            placeholder={t(dict, 'bf.form.message.placeholder')}
            rows="3"
            class="w-full border rounded p-3 text-secondary"
          ></textarea>
          <button type="submit" class="btn-primary px-8 py-3 text-lg w-full font-semibold">
            {t(dict, 'bf.form.submit')}
          </button>
          <p id="msg-bf" class="text-sm mt-2 hidden"></p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('form-bf') as HTMLFormElement | null;
  const msg = document.getElementById('msg-bf');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name = (document.getElementById('name-bf') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email-bf') as HTMLInputElement).value.trim();
    const message = (document.getElementById('message-bf') as HTMLTextAreaElement).value.trim();

    const lang = window.location.pathname.split('/')[1] || 'fr';
    const res = await fetch(`/${lang}/bike-fitting/api/contact/`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, email, message }),
    });

    const data = await res.json();
    msg?.classList.remove('hidden', 'text-red-600', 'text-green-600');

    if (data.success) {
      msg!.textContent = form?.dataset.success ?? '';
      msg?.classList.add('text-green-600');
      form.reset();
    } else {
      msg!.textContent = form?.dataset.error ?? '';
      msg?.classList.add('text-red-600');
    }
    msg?.classList.remove('hidden');
  });
</script>

<style>
  .bf-fade-in {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .bf-fade-in.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  document.querySelectorAll('.bf-fade-in').forEach((el) => observer.observe(el));
</script>
