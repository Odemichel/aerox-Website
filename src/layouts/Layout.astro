---
import VercelAnalytics from '@vercel/analytics/astro';
import { I18N } from 'astrowind:config';
import '~/assets/styles/tailwind.css';

//import CustomAnalytics from '~/components/common/Analytics.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';
import CommonMeta from '~/components/common/CommonMeta.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import Favicons from '~/components/Favicons.astro';
import StickyBar from '~/components/common/StickyBar.astro';

import SpeedInsights from '@vercel/speed-insights/astro';
import { ClientRouter } from 'astro:transitions';
import type { MetaData as MetaDataType } from '~/types';

import merge from 'lodash.merge';
import { SITE } from 'astrowind:config';
import { DEFAULT_LOCALE, SUPPORTED_LOCALES, type Locale } from '~/lib/i18n';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;

// Langue courante depuis l’URL
const seg = Astro.url.pathname.split('/').filter(Boolean)[0] ?? '';
const isLocale = (v: unknown): v is Locale =>
  typeof v === 'string' && (SUPPORTED_LOCALES as readonly string[]).includes(v);
const currentLang: Locale = isLocale(seg) ? seg : DEFAULT_LOCALE;

const { textDirection } = I18N;

/** ✅ Typage sans any pour accéder à metadata_i18n optionnel */
type MetadataI18n = Partial<Record<Locale, Partial<MetaDataType>>>;
type I18nConfig = {
  metadata?: MetaDataType;
  metadata_i18n?: MetadataI18n;
};

const i18nCfg = I18N as unknown as I18nConfig;
const langOverrides = i18nCfg.metadata_i18n?.[currentLang] ?? {};

/** Métadonnées finales : defaults → overrides de langue → metadata de la page */
const effectiveMetadata: MetaDataType = merge({}, i18nCfg.metadata ?? {}, langOverrides, metadata);

/* ===== hreflang helpers ===== */
const ensureTrailingSlash = (p: string) => (!p ? p : p.endsWith('/') || p.includes('.') ? p : p + '/');

/** Blog slug swap: extracts base slug and replaces lang suffix.
 *  e.g. "zwift-fr" + target "en" → "zwift-en" */
const ALL_LANG_SUFFIXES = SUPPORTED_LOCALES as readonly string[];

function blogSlugForLang(slug: string, targetLang: string): string | null {
  const lower = slug.toLowerCase();
  for (const lang of ALL_LANG_SUFFIXES) {
    if (lower.endsWith(`-${lang}`)) {
      const base = slug.slice(0, -(lang.length));
      return `${base}${targetLang}`;
    }
  }
  return null; // slug doesn't end with a known lang suffix
}

function hrefForLang(target: Locale) {
  const parts = Astro.url.pathname.split('/').filter(Boolean);
  const srcLang = (SUPPORTED_LOCALES as readonly string[]).includes(parts[0]) ? parts[0] : null;

  // Swap language prefix
  if (srcLang) parts[0] = target;
  else parts.unshift(target);

  // Swap blog slug lang suffix if we're on a blog article
  if (parts[1] === 'blog' && parts[2] && srcLang !== target) {
    const swapped = blogSlugForLang(parts[2], target);
    if (swapped) parts[2] = swapped;
  }

  const path = ensureTrailingSlash('/' + parts.join('/'));
  const origin = SITE?.site ? new URL(SITE.site).origin : Astro.url.origin;
  return `${origin}${path}`;
}

/* ===== BreadcrumbList schema ===== */
const siteOrigin = SITE?.site ? new URL(SITE.site).origin : Astro.url.origin;
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);

const breadcrumbLabels: Record<string, Record<string, string>> = {
  fr: { fr: 'Accueil', blog: 'Blog', team: 'Équipe', contact: 'Contact', method: 'Méthode', 'bike-fitting': 'Bike Fitting', cda: 'CdA en cyclisme' },
  en: { en: 'Home', blog: 'Blog', team: 'Team', contact: 'Contact', method: 'Method', 'bike-fitting': 'Bike Fitting', cda: 'CdA in cycling' },
  pt: { pt: 'Início', blog: 'Blog', team: 'Equipe', contact: 'Contato', method: 'Método', 'bike-fitting': 'Bike Fitting', cda: 'CdA no ciclismo' },
  es: { es: 'Inicio', blog: 'Blog', team: 'Equipo', contact: 'Contacto', method: 'Método', 'bike-fitting': 'Bike Fitting', cda: 'CdA en ciclismo' },
  it: { it: 'Home', blog: 'Blog', team: 'Team', contact: 'Contatto', method: 'Metodo', 'bike-fitting': 'Bike Fitting', cda: 'CdA nel ciclismo' },
  de: { de: 'Startseite', blog: 'Blog', team: 'Team', contact: 'Kontakt', method: 'Methode', 'bike-fitting': 'Bike Fitting', cda: 'CdA im Radsport' },
  nl: { nl: 'Home', blog: 'Blog', team: 'Team', contact: 'Contact', method: 'Methode', 'bike-fitting': 'Bike Fitting', cda: 'CdA in wielrennen' },
  ja: { ja: 'ホーム', blog: 'ブログ', team: 'チーム', contact: 'お問い合わせ', method: 'メソッド', 'bike-fitting': 'バイクフィッティング', cda: 'サイクリングのCdA' },
  tr: { tr: 'Ana Sayfa', blog: 'Blog', team: 'Ekip', contact: 'İletişim', method: 'Yöntem', 'bike-fitting': 'Bike Fitting', cda: 'Bisiklette CdA' },
};
const labels = breadcrumbLabels[currentLang] ?? breadcrumbLabels.fr;

const breadcrumbItems = pathSegments.map((seg, i) => ({
  '@type': 'ListItem' as const,
  position: i + 1,
  name: labels[seg] ?? seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
  item: `${siteOrigin}${ensureTrailingSlash('/' + pathSegments.slice(0, i + 1).join('/'))}`,
}));

const breadcrumbSchema = breadcrumbItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
} : null;
---

<!doctype html>
<html lang={currentLang} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <!-- ⬇️ passe les metas fusionnées -->
    <Metadata {...effectiveMetadata} />
    <SiteVerification />

    <!-- hreflang alternates -->
    {SUPPORTED_LOCALES.map((l) => { const href = hrefForLang(l); return href ? <link rel="alternate" hreflang={l} href={href} /> : null; })}
    {hrefForLang(DEFAULT_LOCALE) && <link rel="alternate" hreflang="x-default" href={hrefForLang(DEFAULT_LOCALE)} />}

    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}

    <ClientRouter fallback="swap" />
    <!-- Cloudflare Web Analytics -->
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "02eb735f986c4a3aa036cbcf82c0e8c8"}'></script><!-- End Cloudflare Web Analytics -->
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />
    <StickyBar />
    <SpeedInsights />
    <BasicScripts />
    <VercelAnalytics />
  </body>
</html>
